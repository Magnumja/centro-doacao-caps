# URL publica da API em producao, sem barra no final.
# Exemplo Render/Railway/Fly: https://centro-doacao-caps-api.onrender.com
VITE_API_URL="http://localhost:3333"

# Opcional: em localhost, o frontend habilita atalho admin por padrao.
# Em producao isso nao funciona fora de localhost.
VITE_ENABLE_LOCAL_AUTH_BYPASS="false"
