# URL publica da API, sem barra no final.
# Desenvolvimento local: http://localhost:3333
# Producao: use HTTPS. Ex.: https://centro-doacao-caps-api.onrender.com
VITE_API_URL="http://localhost:3333"

# Opcional: em localhost, o frontend habilita atalho admin por padrao.
# Em producao isso nao funciona fora de localhost.
VITE_ENABLE_LOCAL_AUTH_BYPASS="false"

# Opcional: telemetria fica desativada por padrao em desenvolvimento
# para evitar spam de proxy quando a API local nao esta rodando.
# Em producao, deixe "true" se quiser coletar eventos em /api/telemetry.
VITE_ENABLE_TELEMETRY="false"
