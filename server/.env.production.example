# API publicada
NODE_ENV="production"
PORT=3333

# Banco PostgreSQL gerenciado
DATABASE_URL="postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO"

# Gere com: openssl rand -base64 48
JWT_SECRET="cole_aqui_um_segredo_com_32_ou_mais_caracteres"

# URL(s) exatas do frontend publicado, sem barra final.
# Para mais de uma origem, separe por virgula.
FRONTEND_URL="https://seu-site-publico.exemplo.com"

# Ative quando estiver atras de proxy confiavel da plataforma de hospedagem.
TRUST_PROXY="true"

# Nunca ative bypass local em producao.
ENABLE_LOCAL_AUTH_BYPASS="false"

# Admin inicial criado pelo seed. Use senha forte.
SEED_ADMIN_EMAIL="admin@exemplo.com"
SEED_ADMIN_PASSWORD="troque_por_uma_senha_forte"
SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_CAP_SLUG="c1"
