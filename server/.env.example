# URL de conexao com o banco PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/centro_doacao"

# Chave secreta para assinar os JWT; use uma string longa e aleatoria em producao.
# Exemplo: openssl rand -base64 48
JWT_SECRET="troque_por_uma_chave_segura_e_longa"

# URL(s) do front-end para CORS, sem barra no final.
# Para mais de um dominio, separe por virgula:
# FRONTEND_URL="https://seu-site.vercel.app,https://www.seudominio.com.br"
FRONTEND_URL="http://localhost:5173,http://127.0.0.1:5173"

# Porta do servidor (padrao: 3333)
PORT=3333

# Ambiente: development | production
NODE_ENV="development"

# Ative quando a API estiver atras de proxy confiavel em producao
# (Render/Railway/Fly/Ingress). Necessario para IP real e cookies seguros.
TRUST_PROXY="false"

# Em desenvolvimento local, libera acesso administrativo sem login
# apenas quando a requisicao vier de localhost.
ENABLE_LOCAL_AUTH_BYPASS="false"

# Unidade usada quando o bypass local estiver ativo.
LOCAL_AUTH_BYPASS_UNIT_SLUG="c1"

# Credenciais usadas pelo seed para conta administrativa principal.
# Em producao, esses campos sao obrigatorios para evitar credenciais fixas no codigo.
SEED_ADMIN_EMAIL="admin@exemplo.com"
SEED_ADMIN_PASSWORD="troque_por_uma_senha_forte"
