# URL de conexão com o banco PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/centro_doacao"

# Chave secreta para assinar os JWT — use uma string longa e aleatória em produção
# Exemplo: openssl rand -base64 48
JWT_SECRET="troque_por_uma_chave_segura_e_longa"

# URL do front-end para configuração de CORS (sem barra no final)
FRONTEND_URL="http://localhost:5173"

# Porta do servidor (padrão: 3333)
PORT=3333

# Ambiente: development | production
NODE_ENV="development"
